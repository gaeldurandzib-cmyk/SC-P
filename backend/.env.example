/**
 * .env.example
 *
 * Plantilla de variables de entorno para DevShield.
 * Copiar a .env y ajustar valores según el entorno.
 *
 * IMPORTANTE: NUNCA commitear .env al repositorio
 */

# ============================================
# Servidor HTTP
# ============================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ============================================
# Logging
# ============================================
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ============================================
# Autenticación
# ============================================
# Token Bearer para autorizar requests al backend
# Generar con: openssl rand -base64 32
DEVSHIELD_API_TOKEN=devshield-dev-token-change-in-production

# ============================================
# SSH/SFTP (Conexión a servidores remotos)
# ============================================
SSH_HOST=dev.company.com
SSH_PORT=22
SSH_USER=devshield-bot
SSH_KEY_PATH=/home/user/.ssh/id_rsa
SSH_KEY_PASSPHRASE=

# ============================================
# Vault / Criptografía (Futuro)
# ============================================
# Clave maestra para descifrar credenciales almacenadas
VAULT_ENCRYPTION_KEY=your-master-key-min-32-chars-here

# ============================================
# Base de datos (Futuro)
# ============================================
# DATABASE_URL=postgresql://user:pass@localhost/devshield

# ============================================
# Modo de ejecución
# ============================================
# SANDBOX_MODE=docker (en producción: ejecutar linters en contenedores)
# SANDBOX_MODE=native (en desarrollo: ejecutar linters directamente)
SANDBOX_MODE=native
